# Normalize line endings for cross-platform development.
# Shell scripts and Go files must use LF (they run in Linux containers / on ARM target).
*.go        text eol=lf
*.sh        text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.py        text eol=lf
*.sql       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf
